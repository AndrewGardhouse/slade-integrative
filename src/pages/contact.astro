---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Slade Integrative Health | Contact" description="Get in touch with Slade Integrative Health Alliance. We look forward to connecting with you and working together.">
    <main class="flex-1 overflow-hidden container max-w-screen-xl mx-auto px-4 md:px-2">
        <div class="pt-16 text-center mb-8">
            <h1 class="text-4xl font-extrabold mb-4 text-[#2D1505] inline-block">Contact us</h1>
            <h2 class="text-base text-[#365365]">If you would like to learn more about our services, complete the form. We look forward to connecting with you and working together!</h2>
        </div>

        <form id="contact-form" class="mb-12">
            <div class="grid gap-6 mb-6 md:grid-cols-2">
                <div>
                    <label for="first_name" class="block mb-2 text-sm font-medium text-[#2D1505]">First name</label>
                    <input type="text" id="first_name" name="first_name" class="bg-white border border-[#C5D8DE] text-[#2D1505] text-sm rounded-lg focus:ring-[#365365] focus:border-[#365365] block w-full p-2.5" placeholder="John" required />
                </div>
                <div>
                    <label for="last_name" class="block mb-2 text-sm font-medium text-[#2D1505]">Last name</label>
                    <input type="text" id="last_name" name="last_name" class="bg-white border border-[#C5D8DE] text-[#2D1505] text-sm rounded-lg focus:ring-[#365365] focus:border-[#365365] block w-full p-2.5" placeholder="Doe" required />
                </div>
                <div>
                    <label for="email" class="block mb-2 text-sm font-medium text-[#2D1505]">Email address</label>
                    <input type="email" id="email" name="email" class="bg-white border border-[#C5D8DE] text-[#2D1505] text-sm rounded-lg focus:ring-[#365365] focus:border-[#365365] block w-full p-2.5" placeholder="email" required />
                </div>
                <div>
                    <label for="phone" class="block mb-2 text-sm font-medium text-[#2D1505]">Phone number</label>
                    <input type="tel" id="phone" name="phone" class="bg-white border border-[#C5D8DE] text-[#2D1505] text-sm rounded-lg focus:ring-[#365365] focus:border-[#365365] block w-full p-2.5" placeholder="(123) 456-7890" required />
                    <span id="phone-error" class="hidden mt-1 text-xs text-red-500">Please enter a valid phone number.</span>
                </div>
            </div>
            <div class="mb-6">
                <label for="message" class="block mb-2 text-sm font-medium text-[#2D1505]">Message</label>
                <textarea id="message" name="message" class="bg-white border border-[#C5D8DE] text-[#2D1505] text-sm rounded-lg focus:ring-[#365365] focus:border-[#365365] block w-full p-2.5 resize-none" placeholder="message" rows="4" required></textarea>
            </div>
            <div id="form-feedback" class="hidden mb-6 text-sm font-medium"></div>
            <button type="submit" id="submit-btn" class="text-white bg-[#365365] hover:bg-[#1D3A4A] focus:ring-4 focus:outline-none focus:ring-[#365365]/40 font-medium rounded-lg text-sm w-full sm:w-auto px-5 py-2.5 text-center transition-colors duration-200">Submit</button>
        </form>
    </main>
</Layout>

<script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const feedback = document.getElementById('form-feedback') as HTMLDivElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    const phoneInput = document.getElementById('phone') as HTMLInputElement;
    const phoneError = document.getElementById('phone-error') as HTMLSpanElement;

    phoneInput.addEventListener('input', () => {
        const valid = /^[+]?[(]?[0-9]{3}[)]?[-\s.]?[0-9]{3}[-\s.]?[0-9]{4,6}$/.test(phoneInput.value.trim());
        phoneError.classList.toggle('hidden', valid || phoneInput.value === '');
        phoneInput.classList.toggle('border-red-400', !valid && phoneInput.value !== '');
        phoneInput.classList.toggle('border-[#C5D8DE]', valid || phoneInput.value === '');
    });

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const valid = /^[+]?[(]?[0-9]{3}[)]?[-\s.]?[0-9]{3}[-\s.]?[0-9]{4,6}$/.test(phoneInput.value.trim());
        if (!valid) {
            phoneError.classList.remove('hidden');
            phoneInput.focus();
            return;
        }
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';

        const data = {
            first_name: (document.getElementById('first_name') as HTMLInputElement).value,
            last_name: (document.getElementById('last_name') as HTMLInputElement).value,
            email: (document.getElementById('email') as HTMLInputElement).value,
            phone: (document.getElementById('phone') as HTMLInputElement).value,
            message: (document.getElementById('message') as HTMLTextAreaElement).value,
        };

        try {
            const res = await fetch('https://formsubmit.co/ajax/f3bb07d62f133d61a0381b06f23602a3', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify(data),
            });

            if (res.ok) {
                form.reset();
                feedback.textContent = 'Thank you! We will be in touch soon.';
                feedback.className = 'mb-6 text-sm font-medium text-[#365365]';
                submitBtn.disabled = false;
                submitBtn.textContent = 'Submit';
            } else {
                throw new Error();
            }
        } catch {
            feedback.textContent = 'Something went wrong. Please try again or email us directly.';
            feedback.className = 'mb-6 text-sm font-medium text-red-600';
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit';
        }
    });
</script>
