---
import { Image } from '@astrojs/image/components';
import Layout from '../layouts/Layout.astro';
import Logo from '../assets/web/3-4.png'
---

<Layout title="Slade Integrative Health">
	<main class="Hero animate-text flex-1 flex items-center">
		<div class="container max-w-screen-xl mx-auto px-4 md:px-2 py-12">
			<div class="flex flex-col md:flex-row gap-12 items-center">
				<div class="w-full md:w-1/2 flex">
					<Image src={Logo} alt="" class="w-4/5 m-auto">
				</div>
				<div class="md:w-1/2">
					<h1 class="text-center md:text-left text-4xl font-extrabold mb-4 text-[#2D1505]">Slade Integrative Health Alliance</h1>
					<hr class="mb-4 border-[#C5D8DE]">
					<p class="text-base text-center md:text-left text-[#365365]">
						Compassionate, integrative psychotherapy that supports individuals in overcoming mental health challenges.
					</p>
				</div>
			</div>
		</div>
	</main>
</Layout>

<style>
	:global(.animate-text h1),
	:global(.animate-text h2),
	:global(.animate-text h3),
	:global(.animate-text p) {
		opacity: 0;
		transition: opacity 0.8s ease;
	}
	:global(.animate-text h1.visible),
	:global(.animate-text h2.visible),
	:global(.animate-text h3.visible),
	:global(.animate-text p.visible) {
		opacity: 1;
	}
</style>
<script>
	document.addEventListener('DOMContentLoaded', () => {
		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry, i) => {
				if (entry.isIntersecting) {
					setTimeout(() => entry.target.classList.add('visible'), i * 60);
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.1 });
		document.querySelectorAll('.animate-text h1, .animate-text h2, .animate-text h3, .animate-text p').forEach(el => observer.observe(el));
	});
</script>
